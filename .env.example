# ============================================================
# TaskGH Waitlist — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- App URL (used for referral links) ---
NEXT_PUBLIC_APP_URL=https://waitlist.taskgh.com

# --- Email (Brevo) ---
# Get from: https://app.brevo.com → API & Integrations → API Keys
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_LOGO_URL=https://your-cdn.com/logo.png

# --- SMS (FlashSMS Africa) ---
FLASHSMS_API_KEY=your_flashsms_api_key_here
FLASHSMS_SENDER_ID=TaskGH

# --- Admin Auth ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=generate_a_64_char_random_hex_string

# --- Webhook Security ---
# Shared secret sent by Brevo/FlashSMS in the x-webhook-secret header
NOTIFICATION_WEBHOOK_SECRET=choose_a_random_secret

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
